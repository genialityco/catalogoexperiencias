---
// Layout component
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="Geniality - Ecosistemas interactivos para eventos deportivos" />
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Space+Grotesk:wght@600;700&family=Sora:wght@400;600;700;800&display=swap" rel="stylesheet" />
		
		<title>Geniality - Experiencias Interactivas para Eventos</title>
	</head>
	<body class="text-text-primary font-sans overflow-x-hidden bg-brand-dark" style="background: linear-gradient(135deg, #0a0e27 0%, #1a1f3a 100%);">
		<div class="background-texture"></div>
		<nav class="navbar">
			<div class="nav-container">
				<div class="logo">
					<h1 class="text-2xl font-bold font-display"><a href="/" class="bg-gradient-to-r from-brand-cyan via-brand-accent to-brand-purple bg-clip-text text-transparent">Geniality</a></h1>
				</div>
				<ul class="nav-menu">
					<li><a href="/#reto" class="hover:text-brand-cyan transition-colors duration-300">El Reto 2026</a></li>
					<li><a href="/experiencias" class="hover:text-brand-cyan transition-colors duration-300">Catálogo</a></li>
					<li><a href="/ecosistema" class="hover:text-brand-cyan transition-colors duration-300">Ecosistema</a></li>
					<li><a href="/#btl" class="hover:text-brand-cyan transition-colors duration-300">Para Agencias</a></li>
					<li><a href="/planes" class="hover:text-brand-cyan transition-colors duration-300">Inversión</a></li>
				</ul>
				<div class="cta-button">
					<a href="/hablemos" class="btn-demo bg-brand-cyan text-brand-dark px-6 py-3 rounded-xl font-semibold transition-all duration-300 hover:shadow-glow-sm hover:scale-105">
						Cotizar
					</a>
				</div>
			</div>
		</nav>
		<slot />
	</body>
</html>

<style>
	:global(:root) {
		color-scheme: dark;
	}

	:global(html),
	:global(body) {
		color: #f8fafc;
		background-color: #0a0e27;
	}

	/* Fallback defensivo para utilidades de color usadas en la UI */
	:global(.text-text-primary) {
		color: #f8fafc !important;
	}

	:global(.text-text-secondary) {
		color: #cbd5e1 !important;
	}

	:global(.text-text-tertiary) {
		color: #94a3b8 !important;
	}

	:global(.text-gray-400) {
		color: #9ca3af !important;
	}

	:global(.text-white) {
		color: #ffffff !important;
	}

	.navbar {
		position: fixed;
		top: 0;
		width: 100%;
		background: rgba(10, 14, 39, 0.95);
		backdrop-filter: blur(20px);
		-webkit-backdrop-filter: blur(20px);
		z-index: 1001;
		border-bottom: 1px solid rgba(0, 240, 255, 0.1);
		transition: all 0.3s ease;
	}

	.navbar:hover {
		border-bottom-color: rgba(0, 240, 255, 0.2);
		background: rgba(10, 14, 39, 0.98);
	}

	.nav-container {
		max-width: 1400px;
		margin: 0 auto;
		padding: 1.25rem 2rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 3rem;
	}

	.logo {
		flex-shrink: 0;
		font-weight: 800;
	}

	.nav-menu {
		display: flex;
		list-style: none;
		gap: 2.5rem;
		margin: 0;
		padding: 0;
		flex: 1;
		justify-content: center;
	}

	.nav-menu li a {
		font-size: 0.95rem;
		font-weight: 500;
		color: rgb(203, 213, 225);
		text-decoration: none;
		position: relative;
		transition: all 0.3s ease;
	}

	.nav-menu li a::after {
		content: '';
		position: absolute;
		bottom: -4px;
		left: 0;
		width: 0;
		height: 2px;
		background: linear-gradient(90deg, #00f0ff, #06b6d4);
		transition: width 0.3s ease;
	}

	.nav-menu li a:hover::after {
		width: 100%;
	}

	.cta-button {
		flex-shrink: 0;
	}

	.btn-demo {
		display: inline-block;
		text-decoration: none;
		white-space: nowrap;
	}

	@media (max-width: 768px) {
		.nav-menu {
			display: none;
		}

		.nav-container {
			gap: 1rem;
		}
	}
</style>
