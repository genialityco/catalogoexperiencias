		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Space+Grotesk:wght@600;700&family=Sora:wght@400;600;700;800&display=swap" rel="stylesheet" />
		
		<title>Geniality - Experiencias Interactivas para Eventos</title>
	</head>
	<body class="text-text-primary font-sans overflow-x-hidden bg-brand-dark" style="background: linear-gradient(135deg, #0a0e27 0%, #1a1f3a 100%);">
