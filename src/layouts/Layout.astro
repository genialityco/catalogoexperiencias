---
// Layout component
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Geniality - Experiencias Interactivas para Eventos</title>
	</head>
	<body class="text-white font-sans overflow-x-hidden" style="background: transparent;">
		<div class="background-texture"></div>
		<nav class="navbar">
			<div class="nav-container">
				<div class="logo">
					<h1><a href="/">Geniality</a></h1>
				</div>
				<ul class="nav-menu">
					<li><a href="/#reto">El Reto 2026</a></li>
					<li><a href="/experiencias">Catálogo de Experiencias</a></li>
					<li><a href="/ecosistema">Ecosistema</a></li>
					<li><a href="/#btl">Para Agencias BTL</a></li>
					<li><a href="/planes">Modelos de Inversión</a></li>
				</ul>
				<div class="cta-button">
					<a href="/hablemos" class="btn-demo">Cotizar mi Venue</a>
				</div>
			</div>
		</nav>
		<slot />
	</body>
</html>

<style>
	.navbar {
		position: fixed;
		top: 0;
		width: 100%;
		background: rgba(0, 0, 0, 0.9);
		backdrop-filter: blur(10px);
		z-index: 1001;
		border-bottom: 1px solid rgba(255, 255, 255, 0.1);
	}

	.nav-container {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1rem 2rem;
	}

	.logo h1 {
		color: #00ffff;
		font-size: 1.5rem;
		font-weight: 700;
		margin: 0;
		text-shadow: 0 0 10px #00ffff;
	}

	.nav-menu {
		display: flex;
		list-style: none;
		margin: 0;
		padding: 0;
		gap: 2rem;
	}

	.nav-menu a {
		color: #fff;
		text-decoration: none;
		font-weight: 400;
		transition: color 0.3s;
	}

	.nav-menu a:hover {
		color: #00ffff;
	}

	.btn-demo {
		background: linear-gradient(45deg, #00ffff, #ff00ff);
		color: #000;
		padding: 0.5rem 1rem;
		border-radius: 25px;
		text-decoration: none;
		font-weight: 600;
		transition: transform 0.3s;
	}

	.btn-demo:hover {
		transform: scale(1.05);
	}

	@media (max-width: 768px) {
		.nav-container {
			flex-direction: column;
			padding: 1rem;
		}
		.nav-menu {
			margin: 1rem 0;
			gap: 1rem;
		}
	}

	.background-texture {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-image: url('/assets/background-image.png');
		background-size: cover;
		background-position: center;
		background-attachment: fixed;
		opacity: 0.75;
		mix-blend-mode: normal;
		pointer-events: none;
		z-index: 0;
	}

	html {
		position: relative;
	}

	:global(body > :not(.navbar):not(.background-texture)) {
		position: relative;
		z-index: 1;
	}
</style>
