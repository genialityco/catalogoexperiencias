---
import Layout from '../layouts/Layout.astro';
import FooterCTA from '../components/FooterCTA.astro';
---

<Layout>
	<main class="page-content">
		<section class="hero-section">
			<div class="container">
				<h1>Hablemos</h1>
				<p>¿Listo para revolucionar tu venue durante el Mundial 2026? Nuestro equipo está aquí para ayudarte.</p>
			</div>
		</section>

		<section class="contact-section">
			<div class="container">
				<div class="contact-info">
					<h2>Información de Contacto</h2>
					<div class="contact-details">
						<div class="contact-item">
							<h3>📞 Teléfono</h3>
							<p>+57 300 216 2757</p>
						</div>
						<div class="contact-item">
							<h3>📧 Email</h3>
							<p>juan.lopez@geniality.com.co</p>
						</div>
						<div class="contact-item">
							<h3>👤 CEO</h3>
							<p>Juan López</p>
						</div>
						<div class="contact-item">
							<h3>🏢 Empresa</h3>
							<p>Geniality</p>
						</div>
					</div>
				</div>

				<div class="why-contact">
					<h2>¿Por qué contactarnos?</h2>
					<ul>
						<li>Consultoría gratuita y personalizada para tu venue</li>
						<li>Análisis detallado de ROI potencial</li>
						<li>Propuesta técnica adaptada a tus necesidades</li>
						<li>Demo virtual de nuestras experiencias</li>
						<li>Soporte durante todo el proceso de implementación</li>
					</ul>
				</div>
			</div>
		</section>

		<FooterCTA />
	</main>
</Layout>

<style>
	.page-content {
		padding-top: 80px;
	}

	.hero-section {
		background: linear-gradient(135deg, #16213e 0%, #0f3460 100%);
		padding: 5rem 0;
		text-align: center;
		color: #fff;
	}

	.container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	.hero-section h1 {
		font-size: 3rem;
		margin-bottom: 1rem;
	}

	.hero-section p {
		font-size: 1.2rem;
		color: #ccc;
	}

	.contact-section {
		padding: 5rem 0;
		background: #000;
		color: #fff;
	}

	.contact-info h2,
	.why-contact h2 {
		font-size: 2rem;
		color: #00ffff;
		margin-bottom: 2rem;
		text-align: center;
	}

	.contact-details {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: 2rem;
		margin-bottom: 4rem;
	}

	.contact-item {
		text-align: center;
		padding: 2rem;
		background: rgba(255, 255, 255, 0.05);
		border-radius: 15px;
	}

	.contact-item h3 {
		color: #00ffff;
		margin-bottom: 1rem;
	}

	.contact-item p {
		color: #ccc;
		font-size: 1.1rem;
	}

	.why-contact {
		max-width: 600px;
		margin: 0 auto;
	}

	.why-contact ul {
		list-style: none;
		padding: 0;
	}

	.why-contact li {
		padding: 1rem 0;
		border-bottom: 1px solid rgba(255, 255, 255, 0.1);
		position: relative;
		padding-left: 2rem;
		color: #ccc;
	}

	.why-contact li::before {
		content: '✓';
		position: absolute;
		left: 0;
		color: #00ffff;
		font-weight: bold;
	}

	.why-contact li:last-child {
		border-bottom: none;
	}

	@media (max-width: 768px) {
		.contact-details {
			grid-template-columns: 1fr;
		}
		.hero-section h1 {
			font-size: 2rem;
		}
	}
</style>