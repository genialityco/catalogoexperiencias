---
import { getExperiences } from "../../lib/firebase/database";
import Navigation from "../../components/Navigation.astro";
import ImplementationModes from "../../components/ImplementationModes.astro";

const { slug } = Astro.params;

// Traer todas las experiencias y buscar la que coincida con el slug
const experiences = await getExperiences();
const experience =
  experiences.find((exp: any) => String(exp.uid) === String(slug)) ?? null;

// Generar URL de imagen con fallback seguro
const fallbackImage = "/assets/experiences/experiencia-ejemplo1.jpg";
const posterImage = experience?.image || fallbackImage;
const secondImage = experience?.secondImage || null;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>
      {
        experience
          ? `Geniality - ${experience.experiencia}`
          : "Experiencia no encontrada"
      }
    </title>
  </head>

  <body class="bg-black text-white font-sans">
    <Navigation />

    {
      !experience ? (
        <main style="background: #111; color: #fff; font-family: sans-serif; min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 2rem; text-align: center;">
          <h1 style="color: #00ffff; margin-bottom: 1rem;">
            Experiencia no encontrada
          </h1>
          <p style="margin-bottom: 1rem;">
            La experiencia solicitada no existe o ha sido eliminada.
          </p>
          <a
            href="/experiencias"
            style="color: #00ffff; text-decoration: underline;"
          >
            Volver al catálogo
          </a>
        </main>
      ) : (
        <>
          <section class="experience-detail pt-10" style="margin: 10px;">
            <div class="content-container">
              <div class="left-content">
                <h1>{experience.experiencia}</h1>

                <div class="experience-image">
                  <img src={posterImage} alt={experience.experiencia} />
                </div>

                <p>{experience.descripcionDetallada}</p>

                {secondImage && (
                  <div class="experience-image" style="margin-top: 1.5rem;">
                    <img
                      src={secondImage}
                      alt={`Segunda imagen de ${experience.experiencia}`}
                    />
                  </div>
                )}

                <p>{experience.pitchComercial}</p>
              </div>

              <div class="right-content">
                <div class="specs-card">
                  <h3>Ficha Técnica</h3>

                  <div class="spec-item">
                    <strong>Tecnología:</strong>
                    {experience.tecnologia}
                  </div>

                  <a href="/#contacto" class="btn-quote">
                    Cotizar esta experiencia
                  </a>
                </div>
              </div>
            </div>
          </section>

          <ImplementationModes />
        </>
      )
    }
  </body>
</html>

<style>
  .experience-detail {
    min-height: 100vh;
  }

  .hero-video {
    width: 100%;
    height: 60vh;
    overflow: hidden;
    position: relative;
  }

  .hero-video video,
  .hero-video img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .content-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 2rem;
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 4rem;
  }

  .left-content h1 {
    font-size: 3rem;
    color: #00ffff;
    margin-bottom: 2rem;
  }

  .left-content h2 {
    font-size: 1.8rem;
    color: #fff;
    margin: 2rem 0 1rem 0;
  }

  .left-content p {
    color: #ccc;
    line-height: 1.6;
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }

  .experience-image {
    margin: 3rem 0;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .experience-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .right-content {
    position: sticky;
    top: 2rem;
    height: fit-content;
  }

  .specs-card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 15px;
    padding: 2rem;
  }

  .specs-card h3 {
    color: #00ffff;
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .spec-item {
    margin-bottom: 1rem;
    color: #ccc;
  }

  .spec-item strong {
    color: #fff;
    display: block;
    margin-bottom: 0.5rem;
  }

  .btn-quote {
    display: inline-block;
    background: linear-gradient(45deg, #00ffff, #ff00ff);
    color: #000;
    padding: 1rem 2rem;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 600;
    margin-top: 2rem;
    transition: transform 0.3s;
  }

  .btn-quote:hover {
    transform: scale(1.05);
  }

  @media (max-width: 768px) {
    .content-container {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .hero-video {
      height: 40vh;
    }

    .left-content h1 {
      font-size: 2rem;
    }
  }
</style>
