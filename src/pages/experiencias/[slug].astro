---
import { getExperiences } from '../../lib/firebase/database';

export async function getStaticPaths() {
	const experiences = await getExperiences();
	return experiences.map((exp) => ({
		params: { slug: exp.uid },
		props: { experience: exp },
	}));
}

interface Props {
	experience: any;
}

const { experience } = Astro.props;

// Generar URL de video basada en el uid o nombre
const fallbackImage = '/assets/experiences/experiencia-ejemplo1.jpg';
const posterImage = experience.image || fallbackImage;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Geniality - {experience.experiencia}</title>
	</head>
	<body class="bg-black text-white font-sans">
		<nav class="navbar">
			<div class="nav-container">
				<div class="logo">
					<a href="/"><h1>Geniality</h1></a>
				</div>
				<ul class="nav-menu">
					<li><a href="/reto">El Reto 2026</a></li>
					<li><a href="/#experiencias">Catálogo de Experiencias</a></li>
					<li><a href="/#btl">Para Agencias BTL</a></li>
					<li><a href="/#inversion">Modelos de Inversión</a></li>
				</ul>
				<div class="cta-button">
					<a href="/#contacto" class="btn-demo">Cotizar mi Venue</a>
				</div>
			</div>
		</nav>

		<section class="experience-detail mt-5">
			<div class="content-container">
				<div class="left-content">
					<h1>{experience.experiencia}</h1>
					<h2>El Concepto</h2>
					<p>{experience.descripcionDetallada}</p>
					<div class="experience-image">
						<img src={posterImage} alt={experience.experiencia} />
					</div>
					<h2>El Logro Comercial</h2>
					<p>{experience.pitchComercial}</p>
					
				</div>

				<div class="right-content">
					<div class="specs-card">
						<h3>Ficha Técnica</h3>
						<div class="spec-item">
							<strong>Objetivo Principal:</strong>
							{experience.objetivo}
						</div>
						<div class="spec-item">
							<strong>Tecnología:</strong>
							{experience.tecnologia}
						</div>
						<div class="spec-item">
							<strong>Inversión Base (1 Día):</strong>
							{experience.costo}
						</div>
						<a href="/#contacto" class="btn-quote">Cotizar esta experiencia</a>
					</div>
				</div>
			</div>
		</section>
	</body>
</html>

<style>
	.experience-detail {
		min-height: 100vh;
	}

	.hero-video {
		width: 100%;
		height: 60vh;
		overflow: hidden;
		position: relative;
	}

	.hero-video video,
	.hero-video img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.content-container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 4rem 2rem;
		display: grid;
		grid-template-columns: 2fr 1fr;
		gap: 4rem;
	}

	.left-content h1 {
		font-size: 3rem;
		color: #00ffff;
		margin-bottom: 2rem;
	}

	.left-content h2 {
		font-size: 1.8rem;
		color: #fff;
		margin: 2rem 0 1rem 0;
	}

	.left-content p {
		color: #ccc;
		line-height: 1.6;
		font-size: 1.1rem;
		margin-bottom: 2rem;
	}

	.experience-image {
		margin: 3rem 0;
		border-radius: 10px;
		overflow: hidden;
		border: 1px solid rgba(255, 255, 255, 0.1);
	}

	.experience-image img {
		width: 100%;
		height: auto;
		display: block;
	}

	.right-content {
		position: sticky;
		top: 2rem;
		height: fit-content;
	}

	.specs-card {
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 15px;
		padding: 2rem;
	}

	.specs-card h3 {
		color: #00ffff;
		font-size: 1.5rem;
		margin-bottom: 1.5rem;
	}

	.spec-item {
		margin-bottom: 1rem;
		color: #ccc;
	}

	.spec-item strong {
		color: #fff;
		display: block;
		margin-bottom: 0.5rem;
	}

	.btn-quote {
		display: inline-block;
		background: linear-gradient(45deg, #00ffff, #ff00ff);
		color: #000;
		padding: 1rem 2rem;
		border-radius: 50px;
		text-decoration: none;
		font-weight: 600;
		margin-top: 2rem;
		transition: transform 0.3s;
	}

	.btn-quote:hover {
		transform: scale(1.05);
	}

	@media (max-width: 768px) {
		.content-container {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
		.hero-video {
			height: 40vh;
		}
		.left-content h1 {
			font-size: 2rem;
		}
	}

	/* Navbar styles */
	.navbar {
		position: fixed;
		top: 0;
		width: 100%;
		background: rgba(0, 0, 0, 0.9);
		backdrop-filter: blur(10px);
		z-index: 1000;
		border-bottom: 1px solid rgba(255, 255, 255, 0.1);
	}

	.nav-container {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1rem 2rem;
	}

	.logo h1 {
		color: #00ffff;
		font-size: 1.5rem;
		font-weight: 700;
		margin: 0;
		text-shadow: 0 0 10px #00ffff;
	}

	.nav-menu {
		display: flex;
		list-style: none;
		margin: 0;
		padding: 0;
		gap: 2rem;
	}

	.nav-menu a {
		color: #fff;
		text-decoration: none;
		font-weight: 400;
		transition: color 0.3s;
	}

	.nav-menu a:hover {
		color: #00ffff;
	}

	.btn-demo {
		background: linear-gradient(45deg, #00ffff, #ff00ff);
		color: #000;
		padding: 0.5rem 1rem;
		border-radius: 25px;
		text-decoration: none;
		font-weight: 600;
		transition: transform 0.3s;
	}

	.btn-demo:hover {
		transform: scale(1.05);
	}

	@media (max-width: 768px) {
		.nav-container {
			flex-direction: column;
			padding: 1rem;
		}
		.nav-menu {
			margin: 1rem 0;
			gap: 1rem;
		}
	}
</style>
