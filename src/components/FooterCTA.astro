---
// Footer & Contact section
---

<section class="footer-cta relative py-32 md:py-48" id="contacto">
	<!-- Background -->
	<div class="absolute inset-0 overflow-hidden">
		<div class="absolute -top-40 right-0 w-96 h-96 bg-brand-purple/10 rounded-full blur-3xl"></div>
		<div class="absolute -bottom-32 left-0 w-96 h-96 bg-brand-cyan/10 rounded-full blur-3xl"></div>
		<div class="absolute inset-0 bg-gradient-to-br from-brand-dark via-surface-primary to-brand-dark"></div>
	</div>

	<!-- Content -->
	<div class="relative z-10 max-w-5xl mx-auto px-6 md:px-12">
		<!-- Header -->
		<div class="text-center mb-16">
			<h2 class="text-5xl md:text-6xl font-black font-display leading-tight mb-6 text-text-primary">
				MULTIPLICA
				<br />
				<span class="bg-gradient-to-r from-brand-cyan via-brand-accent to-brand-purple bg-clip-text text-transparent">TU RENTABILIDAD</span>
			</h2>
			<p class="text-lg text-text-secondary max-w-2xl mx-auto font-light">
				Cuéntanos sobre tu venue o agencia. Diseñaremos una solución personalizada para maximizar ingresos.
			</p>
		</div>

		<!-- Form -->
		<form class="contact-form bg-gradient-to-br from-surface-primary to-surface-secondary border border-surface-tertiary rounded-2xl p-8 md:p-12 space-y-6 mb-12">
			<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
				<div class="form-group">
					<label for="nombre" class="block text-text-primary font-semibold mb-2 text-sm">Nombre Completo</label>
					<input type="text" id="nombre" name="nombre" class="w-full bg-surface-secondary border border-surface-tertiary text-text-primary rounded-xl px-4 py-3 focus:outline-none focus:border-brand-cyan focus:ring-1 focus:ring-brand-cyan/50 transition-all placeholder-text-tertiary" placeholder="Tu nombre" required>
				</div>
				<div class="form-group">
					<label for="empresa" class="block text-text-primary font-semibold mb-2 text-sm">Empresa / Venue</label>
					<input type="text" id="empresa" name="empresa" class="w-full bg-surface-secondary border border-surface-tertiary text-text-primary rounded-xl px-4 py-3 focus:outline-none focus:border-brand-cyan focus:ring-1 focus:ring-brand-cyan/50 transition-all placeholder-text-tertiary" placeholder="Nombre del lugar" required>
				</div>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
				<div class="form-group">
					<label for="tipo" class="block text-text-primary font-semibold mb-2 text-sm">¿Eres Venue o Agencia?</label>
					<select id="tipo" name="tipo" class="w-full bg-surface-secondary border border-surface-tertiary text-text-primary rounded-xl px-4 py-3 focus:outline-none focus:border-brand-cyan focus:ring-1 focus:ring-brand-cyan/50 transition-all" required>
						<option value="">Selecciona una opción</option>
						<option value="venue">Venue (Hotel/Bar/Estadio)</option>
						<option value="agencia">Agencia/Productora</option>
					</select>
				</div>
				<div class="form-group">
					<label for="interes" class="block text-text-primary font-semibold mb-2 text-sm">¿Qué te Interesa?</label>
					<select id="interes" name="interes" class="w-full bg-surface-secondary border border-surface-tertiary text-text-primary rounded-xl px-4 py-3 focus:outline-none focus:border-brand-cyan focus:ring-1 focus:ring-brand-cyan/50 transition-all" required>
						<option value="">Selecciona una opción</option>
						<option value="individual">Experiencia Individual</option>
						<option value="completo">Ecosistema Completo</option>
						<option value="alianza">Alianza Estratégica</option>
					</select>
				</div>
			</div>

			<div class="form-group">
				<label for="mensaje" class="block text-text-primary font-semibold mb-2 text-sm">Mensaje (Opcional)</label>
				<textarea id="mensaje" name="mensaje" rows="4" class="w-full bg-surface-secondary border border-surface-tertiary text-text-primary rounded-xl px-4 py-3 focus:outline-none focus:border-brand-cyan focus:ring-1 focus:ring-brand-cyan/50 transition-all placeholder-text-tertiary" placeholder="Cuéntanos más..."></textarea>
			</div>

			<button type="submit" class="w-full bg-brand-cyan text-brand-dark font-bold py-3 px-6 rounded-xl transition-all duration-300 hover:shadow-glow-sm hover:scale-105 mt-8">
				Enviar Consulta
			</button>
		</form>

		<!-- Contact Info -->
		<div class="text-center">
			<p class="text-text-secondary text-sm mb-6 font-light">¿Prefieres contactar directamente?</p>
			<div class="space-y-3">
				<div class="text-text-primary font-semibold">
					<span class="text-brand-cyan">WhatsApp:</span> +57 300 216 2757
				</div>
				<div class="text-text-primary font-semibold">
					<span class="text-brand-cyan">Email:</span> juan.lopez@geniality.com.co
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.footer-cta {
		background: linear-gradient(135deg, #0a0e27 0%, #1a1f3a 100%);
	}

	.form-group input::placeholder,
	.form-group textarea::placeholder {
		color: rgb(148, 163, 184);
	}

	.form-group input:focus::placeholder,
	.form-group textarea:focus::placeholder {
		color: rgb(148, 163, 184);
	}

	@media (max-width: 768px) {
		.footer-cta h2 {
			font-size: 2.5rem;
		}
	}
</style>