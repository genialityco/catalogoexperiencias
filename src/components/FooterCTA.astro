---
// Footer & Contact section
import ContactForm from './ContactForm.astro';
---

<section class="footer-cta relative py-32 md:py-48" id="contacto">
	<!-- Background -->
	<div class="absolute inset-0 overflow-hidden">
		<div class="absolute -top-40 right-0 w-96 h-96 bg-brand-purple/10 rounded-full blur-3xl"></div>
		<div class="absolute -bottom-32 left-0 w-96 h-96 bg-brand-cyan/10 rounded-full blur-3xl"></div>
		<div class="absolute inset-0 bg-gradient-to-br from-brand-dark via-surface-primary to-brand-dark"></div>
	</div>

	<!-- Content -->
	<div class="relative z-10 max-w-5xl mx-auto px-6 md:px-12">
		<!-- Header -->
		<div class="text-center mb-16">
			<h2 class="text-5xl md:text-6xl font-black font-display leading-tight mb-6 text-text-primary">
				MULTIPLICA
				<br />
				<span class="bg-gradient-to-r from-brand-cyan via-brand-accent to-brand-purple bg-clip-text text-transparent">TU RENTABILIDAD</span>
			</h2>
			<p class="text-lg text-text-secondary max-w-2xl mx-auto font-light">
				Cuéntanos sobre tu venue o agencia. Diseñaremos una solución personalizada para maximizar ingresos.
			</p>
		</div>

		<!-- Form -->
		<div class="contact-form-card mb-12">
			<ContactForm submitLabel="Enviar Consulta" />
		</div>

		<!-- Contact Info -->
		<div class="text-center">
			<p class="text-text-secondary text-sm mb-6 font-light">¿Prefieres contactar directamente?</p>
			<div class="space-y-3">
				<div class="text-text-primary font-semibold">
					<span class="text-brand-cyan">WhatsApp:</span> +57 300 216 2757
				</div>
				<div class="text-text-primary font-semibold">
					<span class="text-brand-cyan">Email:</span> juan.lopez@geniality.com.co
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.footer-cta {
		background: linear-gradient(135deg, #0a0e27 0%, #1a1f3a 100%);
	}

	.contact-form-card {
		padding: 2rem;
		border: 1px solid rgba(0, 255, 255, 0.25);
		border-radius: 18px;
		background: rgba(15, 52, 96, 0.25);
		backdrop-filter: blur(6px);
	}

	@media (max-width: 768px) {
		.footer-cta h2 {
			font-size: 2.5rem;
		}
	}
</style>