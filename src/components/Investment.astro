<style>
	.investment {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	.section-title {
		font-size: 2.5rem;
		font-weight: 700;
		color: #fff;
		text-align: center;
		margin-bottom: 1rem;
	}

	.intro {
		font-size: 1.2rem;
		color: #ccc;
		text-align: center;
		max-width: 800px;
		margin: 0 auto 3rem;
		line-height: 1.6;
	}

	.tabs {
		display: flex;
		justify-content: center;
		gap: 1rem;
		margin-bottom: 3rem;
		flex-wrap: wrap;
	}

	.tab-btn {
		background: rgba(255, 255, 255, 0.1);
		border: 1px solid rgba(255, 255, 255, 0.2);
		color: #fff;
		padding: 0.75rem 1.5rem;
		border-radius: 25px;
		cursor: pointer;
		transition: all 0.3s;
		font-weight: 500;
	}

	.tab-btn.active,
	.tab-btn:hover {
		background: #00ffff;
		color: #000;
		border-color: #00ffff;
	}

	.tab-content {
		display: none;
	}

	.tab-content.active {
		display: block;
	}

	.pricing-header {
		text-align: center;
		margin-bottom: 2rem;
	}

	.pricing-header h3 {
		font-size: 2rem;
		color: #00ffff;
		font-weight: 700;
	}

	.pricing-details {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
	}

	.option {
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 15px;
		padding: 2rem;
		transition: transform 0.3s;
	}

	.option:hover {
		transform: translateY(-5px);
	}

	.option.upgrade {
		border-color: #ffaa00;
		background: rgba(255, 170, 0, 0.05);
		position: relative;
	}

	.option.upgrade::before {
		content: '👑';
		position: absolute;
		top: -10px;
		right: -10px;
		font-size: 2rem;
	}

	.option h4 {
		font-size: 1.3rem;
		font-weight: 600;
		color: #00ffff;
		margin-bottom: 0.5rem;
	}

	.option.upgrade h4 {
		color: #ffaa00;
	}

	.option p {
		color: #ccc;
		margin-bottom: 1rem;
		line-height: 1.6;
	}

	.option ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.option li {
		color: #ccc;
		margin-bottom: 0.5rem;
		padding-left: 1rem;
		position: relative;
	}

	.option li::before {
		content: '✓';
		position: absolute;
		left: 0;
		color: #00ffff;
		font-weight: bold;
	}

	.additional {
		font-size: 0.9rem;
		color: #aaa;
		font-style: italic;
		margin-top: 1rem;
	}

	@media (max-width: 768px) {
		.tabs {
			flex-direction: column;
			align-items: center;
		}
		.pricing-details {
			grid-template-columns: 1fr;
		}
		.section-title {
			font-size: 2rem;
		}
	}
</style>

<script>
	document.addEventListener('DOMContentLoaded', function() {
		const tabBtns = document.querySelectorAll('.tab-btn');
		const tabContents = document.querySelectorAll('.tab-content');

		tabBtns.forEach(btn => {
			btn.addEventListener('click', function() {
				// Remove active class from all buttons
				tabBtns.forEach(b => b.classList.remove('active'));
				// Add active class to clicked button
				this.classList.add('active');

				const tabId = this.getAttribute('data-tab');

				// Hide all tab contents
				tabContents.forEach(content => {
					content.classList.remove('active');
				});

				// Show selected tab content
				document.getElementById(tabId).classList.add('active');
			});
		});
	});
</script>