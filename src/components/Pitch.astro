---
// Pitch Global section - El Problema y La Promesa
import LiquidEffect from './LiquidEffect.jsx';
---

<section class="pitch relative py-32 md:py-48 overflow-hidden">
	<!-- Background decoration -->
	<div class="absolute inset-0 overflow-hidden">
		<div class="absolute top-0 right-0 w-96 h-96 bg-brand-purple/10 rounded-full blur-3xl"></div>
		<div class="absolute bottom-0 left-0 w-80 h-80 bg-brand-cyan/10 rounded-full blur-3xl"></div>
	</div>

	<div class="container relative z-10 max-w-7xl mx-auto px-6 md:px-12">
		<!-- Header -->
		<div class="mb-20 max-w-4xl">
			<h2 class="text-5xl md:text-7xl font-black font-display leading-tight mb-6 text-text-primary">
				De Cartelera
				<br />
				<span class="bg-gradient-to-r from-brand-cyan via-brand-accent to-brand-purple bg-clip-text text-transparent">a Referente Digital</span>
			</h2>
			<p class="text-lg md:text-xl text-text-secondary leading-relaxed font-light max-w-2xl">
				La gente va, ve el partido y se va. Rompe ese ciclo con tecnología diseñada para entender la euforia colectiva y transformarla en oportunidad.
			</p>
		</div>

		<!-- Metrics Grid -->
		<div class="pitch-cards grid grid-cols-1 md:grid-cols-3 gap-8">
			<!-- Card 1 -->
			<div class="group relative bg-gradient-to-br from-surface-primary to-surface-secondary border border-surface-tertiary rounded-2xl p-8 hover:border-brand-cyan transition-all duration-500 hover:shadow-card-hover cursor-pointer">
				<div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-brand-cyan/0 to-brand-cyan/0 group-hover:from-brand-cyan/5 group-hover:to-brand-cyan/5 transition-colors duration-300"></div>
				<div class="relative z-10">
					<div class="inline-flex items-center justify-center w-16 h-16 bg-brand-cyan/10 border border-brand-cyan/30 rounded-xl mb-6 group-hover:bg-brand-cyan/20 transition-colors duration-300">
						<span class="text-3xl">↗️</span>
					</div>
					<h3 class="text-4xl font-black font-display text-brand-cyan mb-3">+300%</h3>
					<p class="text-text-secondary font-light leading-relaxed">
						Retención de audiencias en el venue durante partidos
					</p>
				</div>
			</div>

			<!-- Card 2 -->
			<div class="group relative bg-gradient-to-br from-surface-primary to-surface-secondary border border-surface-tertiary rounded-2xl p-8 hover:border-brand-purple transition-all duration-500 hover:shadow-card-hover cursor-pointer">
				<div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-brand-purple/0 to-brand-purple/0 group-hover:from-brand-purple/5 group-hover:to-brand-purple/5 transition-colors duration-300"></div>
				<div class="relative z-10">
					<div class="inline-flex items-center justify-center w-16 h-16 bg-brand-purple/10 border border-brand-purple/30 rounded-xl mb-6 group-hover:bg-brand-purple/20 transition-colors duration-300">
						<span class="text-3xl">💰</span>
					</div>
					<h3 class="text-4xl font-black font-display text-brand-purple mb-3">F&B+</h3>
					<p class="text-text-secondary font-light leading-relaxed">
						Aceleración de compras impulsivas sincronizadas con momentos clave
					</p>
				</div>
			</div>

			<!-- Card 3 -->
			<div class="group relative bg-gradient-to-br from-surface-primary to-surface-secondary border border-surface-tertiary rounded-2xl p-8 hover:border-brand-pink transition-all duration-500 hover:shadow-card-hover cursor-pointer">
				<div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-brand-pink/0 to-brand-pink/0 group-hover:from-brand-pink/5 group-hover:to-brand-pink/5 transition-colors duration-300"></div>
				<div class="relative z-10">
					<div class="inline-flex items-center justify-center w-16 h-16 bg-brand-pink/10 border border-brand-pink/30 rounded-xl mb-6 group-hover:bg-brand-pink/20 transition-colors duration-300">
						<span class="text-3xl">📊</span>
					</div>
					<h3 class="text-4xl font-black font-display text-brand-pink mb-3">LEADS</h3>
					<p class="text-text-secondary font-light leading-relaxed">
						Convierte tu ecosistema en un activo digital revendible a patrocinadores
					</p>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.pitch {
		background: linear-gradient(135deg, #0a0e27 0%, #1a1f3a 100%);
	}

	.pitch-cards {
		animation: slideUp 0.6s ease-out forwards;
	}

	@keyframes slideUp {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
</style>