---
// Hero section component
import EnergyAura from './EnergyAura.jsx';
---

<section class="hero relative min-h-screen flex items-center justify-center overflow-hidden bg-black/30">
	<!-- <EnergyAura client:only="react" /> -->
	<div class="hero-background absolute inset-0 bg-cover bg-center" style="background-image: url('/assets/heroimage.png');">
		<!-- Placeholder image used until the video is ready -->
		<!--
		<video autoplay muted loop class="w-full h-full object-cover opacity-20">
			<source src="/videos/hero-loop.mp4" type="video/mp4">
			<div class="absolute inset-0 bg-gradient-to-r from-cyan-500/20 to-purple-500/20"></div>
		</video>
		-->
		<div class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
	</div>
	<div class="hero-content relative z-10 text-left max-w-6xl px-6 md:px-12">
		<div class="mb-12 md:mb-16">
			<h1 class="hero-title text-7xl sm:text-8xl md:text-9xl lg:text-9xl font-black leading-none mb-2 text-white">
				EL MUNDIAL
			</h1>
			<h1 class="hero-title text-7xl sm:text-8xl md:text-9xl lg:text-9xl font-black leading-none mb-2 bg-gradient-to-r from-cyan-400 to-purple-400 bg-clip-text text-transparent">
				NO SE VE
			</h1>
			<h1 class="hero-title text-7xl sm:text-8xl md:text-9xl lg:text-9xl font-black leading-none text-white">
				SE VIVE
			</h1>
		</div>
		<div class="max-w-3xl mb-12">
			<p class="hero-subtitle text-lg md:text-xl text-gray-400 leading-relaxed">
				Ecosistemas interactivos que transforman los 90 minutos en experiencias que tus hinchas nunca olvidarán.
			</p>
		</div>
		<div class="cta-buttons flex flex-col sm:flex-row gap-4 mb-16">
			<a href="#experiencias" class="btn-cta primary bg-white text-black px-8 py-4 rounded-full font-bold transition-all duration-300 transform hover:scale-105 hover:shadow-2xl">
				Explorar
			</a>
			<a href="#btl" class="btn-cta secondary border-2 border-white text-white px-8 py-4 rounded-full font-bold transition-all duration-300 transform hover:bg-white hover:text-black">
				BTL & Productoras
			</a>
		</div>
		<div class="scroll-indicator text-gray-400 text-sm font-light">
			↓ SCROLL DOWN
		</div>
	</div>
</section>

<style>
	.hero-title {
		text-shadow: 0 2px 10px rgba(0, 0, 0, 0.7);
	}
</style>
