---
// Hero section component
import EnergyAura from './EnergyAura.jsx';
---

<section class="hero relative min-h-screen flex flex-col items-center justify-center text-center overflow-hidden pt-20">
	<!-- Animated Background -->
	<div class="absolute inset-0 overflow-hidden">
		<div class="absolute -top-40 -right-40 w-80 h-80 bg-brand-purple/20 rounded-full blur-3xl animate-pulse-slow"></div>
		<div class="absolute -bottom-32 -left-32 w-96 h-96 bg-brand-cyan/15 rounded-full blur-3xl animate-float"></div>
		<div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-brand-dark/50"></div>
	</div>

	<!-- Background Image with Overlay -->
	<div class="absolute inset-0 opacity-20">
		<img src="/assets/heroimage.png" class="w-full h-full object-cover" alt="background" />
		<div class="absolute inset-0 bg-brand-dark/70 backdrop-blur-sm"></div>
	</div>

	<!-- Content -->
	<div class="hero-content relative z-10 max-w-5xl px-6 md:px-12 py-24">
		<!-- Pre-heading Badge -->
		<div class="mb-8 inline-flex items-center gap-2 px-4 py-2 rounded-full border border-brand-cyan/30 bg-brand-cyan/5 backdrop-blur-sm">
			<span class="text-xs font-semibold text-brand-cyan tracking-widest uppercase">2026 - Nuevo Era</span>
		</div>

		<!-- Main Headlines -->
		<div class="mb-8 space-y-4">
			<h1 class="text-7xl sm:text-8xl md:text-9xl font-black font-display leading-none text-text-primary">
				EL MUNDIAL
			</h1>
			<div class="h-1.5 w-32 bg-gradient-to-r from-brand-cyan via-brand-accent to-brand-purple rounded-full"></div>
			<h2 class="text-6xl sm:text-7xl md:text-8xl font-black font-display leading-tight">
				<span class="bg-gradient-to-r from-brand-cyan via-brand-accent to-brand-purple bg-clip-text text-transparent">
					NO SE VE
				</span>
				<br />
				<span class="text-text-primary">SE VIVE</span>
			</h2>
		</div>

		<!-- Description -->
		<div class="max-w-2xl mb-12">
			<p class="text-lg md:text-xl text-text-secondary leading-relaxed font-light">
				Ecosistemas interactivos que transforman los 90 minutos en experiencias que tus hinchas nunca olvidarán. Generamos ingresos, emoción y conexión.
			</p>
		</div>

		<!-- CTA Buttons -->
		<div class="flex flex-col sm:flex-row gap-4 mb-16">
			<a href="#experiencias" class="btn-primary">Explorar Experiencias</a>
			<a href="#contacto" class="btn-secondary">Contáctanos</a>
		</div>
	</div>
</section>

<style>
.hero {
	background: linear-gradient(135deg, #0a0e27 0%, #1a1f3a 100%);
}
.btn-primary {
	background: linear-gradient(to right, #06b6d4, #9333ea);
	color: white;
	padding: 0.75rem 1.5rem;
	border-radius: 9999px;
	font-weight: bold;
	transition: transform 0.3s ease, box-shadow 0.3s ease;
}
.btn-primary:hover {
	transform: scale(1.05);
	box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
}
.btn-secondary {
	background: transparent;
	border: 2px solid #06b6d4;
	color: #06b6d4;
	padding: 0.75rem 1.5rem;
	border-radius: 9999px;
	font-weight: bold;
	transition: transform 0.3s ease, box-shadow 0.3s ease;
}
.btn-secondary:hover {
	transform: scale(1.05);
	box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
}
</style>
