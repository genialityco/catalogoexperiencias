---
// Hero section component
---
import EnergyAura from './EnergyAura.jsx';

<section class="hero relative min-h-screen flex items-center justify-center overflow-hidden bg-gradient-to-br from-slate-900 via-purple-900 to-slate-900">
	<!-- <EnergyAura client:only="react" /> -->
	<div class="hero-background absolute inset-0">
		<!-- Video en bucle: hinchas saltando frente a pantalla interactiva vs meseros entregando bebidas -->
		<video autoplay muted loop class="w-full h-full object-cover opacity-20">
			<source src="/videos/hero-loop.mp4" type="video/mp4">
			<!-- Fallback placeholder -->
			<div class="absolute inset-0 bg-gradient-to-r from-cyan-500/20 to-purple-500/20"></div>
		</video>
		<div class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
	</div>
	<div class="hero-content relative z-10 text-center max-w-4xl px-6">
		<h1 class="hero-title text-5xl md:text-7xl lg:text-8xl font-bold mb-6 bg-gradient-to-r from-cyan-400 via-purple-400 to-pink-400 bg-clip-text text-transparent animate-pulse">
			EL MUNDIAL NO SE VE. SE VIVE.
		</h1>
		<p class="hero-subtitle text-lg md:text-xl lg:text-2xl text-gray-300 mb-8 leading-relaxed">
			Ecosistemas interactivos que transforman la atención de los hinchas en rentabilidad para tu venue durante los 90 minutos del partido (y mucho después).
		</p>
		<div class="cta-buttons flex flex-col sm:flex-row gap-4 justify-center">
			<a href="#experiencias" class="btn-cta primary bg-gradient-to-r from-cyan-500 to-purple-500 hover:from-cyan-600 hover:to-purple-600 text-white px-8 py-4 rounded-full font-semibold transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-cyan-500/25">
				Explorar Experiencias
			</a>
			<a href="#btl" class="btn-cta secondary border-2 border-cyan-400 text-cyan-400 hover:bg-cyan-400 hover:text-black px-8 py-4 rounded-full font-semibold transition-all duration-300 transform hover:scale-105">
				¿Eres Agencia BTL o Productora? Haz clic aquí.
			</a>
		</div>
	</div>
</section>

