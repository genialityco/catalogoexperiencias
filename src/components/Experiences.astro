---
// Interactive Feed section - Catálogo de Experiencias
import PixelReveal from './PixelReveal.jsx';
---
<section id="experiencias" class="experiences relative py-20 bg-gradient-to-b from-gray-900 via-black to-gray-900">
	<div class="container relative z-10 max-w-6xl mx-auto px-6">
		<h2 class="section-title text-4xl md:text-5xl lg:text-6xl font-bold text-center mb-4 bg-gradient-to-r from-cyan-400 via-purple-400 to-pink-400 bg-clip-text text-transparent">
			EL FEED INTERACTIVO
		</h2>
		<p class="section-subtitle text-xl md:text-2xl text-cyan-400 text-center mb-12 font-semibold">
			Catálogo de Experiencias
		</p>
		
		<!-- Filters -->
		<div class="filters flex justify-center gap-4 mb-12 flex-wrap">
			<button class="filter-btn active bg-cyan-500 text-black px-6 py-3 rounded-full font-semibold transition-all duration-300 hover:scale-105 shadow-lg">
				Todas
			</button>
			<button class="filter-btn bg-gray-800 text-white px-6 py-3 rounded-full font-semibold transition-all duration-300 hover:bg-cyan-500 hover:text-black hover:scale-105">
				F&B (Alimentos y Bebidas)
			</button>
			<button class="filter-btn bg-gray-800 text-white px-6 py-3 rounded-full font-semibold transition-all duration-300 hover:bg-purple-500 hover:text-black hover:scale-105">
				Locales
			</button>
		</div>
		
		<!-- Feed Grid -->
		<div class="feed-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
			<div class="feed-card group relative bg-gradient-to-br from-cyan-900/20 to-purple-900/20 backdrop-blur-sm border border-cyan-500/20 rounded-2xl overflow-hidden hover:border-cyan-400/50 transition-all duration-500 hover:transform hover:scale-105 hover:shadow-2xl hover:shadow-cyan-500/10" data-category="fnb">
				<div class="card-video relative h-48 overflow-hidden">
					<!-- Video QR Gigante -->
					<div class="relative w-full h-full">
						<img src="/src/assets/experiences/experiencia-ejemplo1.jpg" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
					</div>
					<div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
				</div>
				<div class="card-content p-6 text-center">
					<h3 class="text-xl font-bold text-white mb-4 group-hover:text-cyan-400 transition-colors">Menú Dinámico Flash</h3>
					<a href="/experiencias/menu-dinamico" class="inline-block bg-gradient-to-r from-cyan-500 to-purple-500 text-white px-6 py-3 rounded-full font-semibold transition-all duration-300 hover:scale-105 shadow-lg">
						Ver a detalle y cotizar
					</a>
				</div>
			</div>
			
			<div class="feed-card group relative bg-gradient-to-br from-purple-900/20 to-pink-900/20 backdrop-blur-sm border border-purple-500/20 rounded-2xl overflow-hidden hover:border-purple-400/50 transition-all duration-500 hover:transform hover:scale-105 hover:shadow-2xl hover:shadow-purple-500/10" data-category="locales">
				<div class="card-video relative h-48 overflow-hidden">
					<!-- Video de banderas compitiendo -->
					<div class="relative w-full h-full">
						<img src="/src/assets/experiences/experiencia-ejemplo2.jpg" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
					</div>
					<div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
				</div>
				<div class="card-content p-6 text-center">
					<h3 class="text-xl font-bold text-white mb-4 group-hover:text-purple-400 transition-colors">Gritómetro de Dominio</h3>
					<a href="/experiencias/gritometro-dominio" class="inline-block bg-gradient-to-r from-purple-500 to-pink-500 text-white px-6 py-3 rounded-full font-semibold transition-all duration-300 hover:scale-105 shadow-lg">
						Ver a detalle y cotizar
					</a>
				</div>
			</div>
			
			<div class="feed-card group relative bg-gradient-to-br from-pink-900/20 to-cyan-900/20 backdrop-blur-sm border border-pink-500/20 rounded-2xl overflow-hidden hover:border-pink-400/50 transition-all duration-500 hover:transform hover:scale-105 hover:shadow-2xl hover:shadow-pink-500/10" data-category="fnb locales">
				<div class="card-video relative h-48 overflow-hidden">
					<!-- Video de medidor explotando -->
					<div class="relative w-full h-full">
						<img src="/src/assets/experiences/experiencia-ejemplo3.png" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
					</div>
					<div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
				</div>
				<div class="card-content p-6 text-center">
					<h3 class="text-xl font-bold text-white mb-4 group-hover:text-pink-400 transition-colors">Termómetro de Tensión</h3>
					<a href="/experiencias/termometro-tension" class="inline-block bg-gradient-to-r from-pink-500 to-cyan-500 text-white px-6 py-3 rounded-full font-semibold transition-all duration-300 hover:scale-105 shadow-lg">
						Ver a detalle y cotizar
					</a>
				</div>
			</div>
		</div>
	</div>
</section>

<script>
	document.addEventListener('DOMContentLoaded', function() {
		const filterBtns = document.querySelectorAll('.filter-btn');
		const feedCards = document.querySelectorAll('.feed-card');

		filterBtns.forEach(btn => {
			btn.addEventListener('click', function() {
				// Remove active class from all buttons
				filterBtns.forEach(b => {
					b.classList.remove('active', 'bg-cyan-500', 'text-black');
					b.classList.add('bg-gray-800', 'text-white');
				});
				
				// Add active class to clicked button
				this.classList.add('active', 'bg-cyan-500', 'text-black');
				this.classList.remove('bg-gray-800', 'text-white');

				const filterText = this.textContent.toLowerCase().trim();
				const filterMap = {
					'todas': 'all',
					'f&b (alimentos y bebidas)': 'fnb',
					'locales': 'locales'
				};
				const filterValue = filterMap[filterText] || 'all';

				feedCards.forEach(card => {
					const categories = card.getAttribute('data-category').split(' ');
					
					if (filterValue === 'all' || categories.includes(filterValue)) {
						card.style.display = 'block';
					} else {
						card.style.display = 'none';
					}
				});
			});
		});
	});
</script>


</section>

