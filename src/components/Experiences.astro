---
// Catálogo dinámico de experiencias
---

<section id="experiencias" class="experiences relative py-24 bg-black/40">
  <div class="container relative z-10 max-w-6xl mx-auto px-6 md:px-12">
    <div class="mb-12">
      <h2 class="section-title text-6xl md:text-7xl font-black leading-tight mb-4 text-white">
        EXPERIENCIAS
      </h2>
      <p class="section-subtitle text-lg text-gray-400 max-w-2xl">
        Catálogo dinámico de experiencias interactivas.
      </p>
    </div>

    <div id="experiences-grid" class="feed-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <article class="feed-card group relative bg-black border border-gray-800 rounded-lg overflow-hidden p-6">
        <p class="text-gray-400">Cargando experiencias...</p>
      </article>
    </div>
  </div>
</section>

<script>
  import { getExperiences } from '../lib/firebase/database';

  const grid = document.querySelector('#experiences-grid');
  const fallbackImage = '/assets/experiences/experiencia-ejemplo1.jpg';

  const normalize = (value: string) =>
    value
      .toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '');

  const resolveDetailPath = (uid: string) => {
    return `/experiencias/${uid}`;
  };

  const render = async () => {
    if (!(grid instanceof HTMLDivElement)) return;

    try {
      const experiences = await getExperiences();
      const visibleExperiences = experiences.filter((exp) => exp.visible === true);

      if (!visibleExperiences.length) {
        grid.innerHTML = `
          <article class="feed-card group relative bg-black border border-gray-800 rounded-lg overflow-hidden p-6">
            <p class="text-gray-400">Aún no hay experiencias publicadas.</p>
          </article>
        `;
        return;
      }

      grid.innerHTML = visibleExperiences
        .map(
          (exp) => `
          <article class="feed-card group relative bg-black border border-gray-800 rounded-lg overflow-hidden hover:border-white transition-all duration-500">
            <div class="card-video relative h-64 overflow-hidden bg-gray-900">
              <img
                src="${exp.image || fallbackImage}"
                alt="${exp.experiencia}"
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
              />
            </div>
            <div class="card-content p-8">
              <h3 class="text-2xl font-black text-white mb-3">${exp.experiencia}</h3>
              <p class="text-sm text-gray-400">${exp.descripcionDetallada}</p>
              <a
                href="${resolveDetailPath(exp.uid)}"
                class="inline-block mt-6 bg-gradient-to-r from-cyan-400 to-fuchsia-500 text-black font-bold px-5 py-2 rounded-full hover:scale-105 transition-transform duration-300"
              >
                Explorar
              </a>
            </div>
          </article>
        `
        )
        .join('');
    } catch (error) {
      console.error('Error cargando experiencias:', error);
      grid.innerHTML = `
        <article class="feed-card group relative bg-black border border-gray-800 rounded-lg overflow-hidden p-6">
          <p class="text-red-400">No se pudieron cargar las experiencias.</p>
        </article>
      `;
    }
  };

  render();
</script>

<style>
  .section-title {
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
  }
</style>
