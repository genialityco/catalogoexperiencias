---
// Navigation component
---

<nav class="navbar">
	<div class="nav-container">
		<div class="logo">
			<h1>Geniality</h1>
		</div>
		<ul class="nav-menu">
			<li><a href="/reto">El Reto 2026</a></li>
			<li><a href="#experiencias">Catálogo de Experiencias</a></li>
			<li><a href="#btl">Para Agencias BTL</a></li>
			<li><a href="#inversion">Modelos de Inversión</a></li>
		</ul>
		<div class="cta-button">
			<a href="#contacto" class="btn-demo">Cotizar mi Venue</a>
		</div>
	</div>
</nav>

<style>
	.navbar {
		position: fixed;
		top: 0;
		width: 100%;
		background: rgba(0, 0, 0, 0.9);
		backdrop-filter: blur(10px);
		z-index: 1000;
		border-bottom: 1px solid rgba(255, 255, 255, 0.1);
	}

	.nav-container {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1rem 2rem;
	}

	.logo h1 {
		color: #ffffff;
		font-size: 1.2rem;
		font-weight: 900;
		margin: 0;
		letter-spacing: -0.02em;
	}

	.nav-menu {
		display: flex;
		list-style: none;
		margin: 0;
		padding: 0;
		gap: 2rem;
	}

	.nav-menu a {
		color: #fff;
		text-decoration: none;
		font-weight: 400;
		transition: color 0.3s;
	}

	.nav-menu a:hover {
		color: #ffffff;
	}

	.btn-demo {
		background: #ffffff;
		color: #000;
		padding: 0.5rem 1.25rem;
		border-radius: 25px;
		text-decoration: none;
		font-weight: 700;
		font-size: 0.875rem;
		transition: all 0.3s;
	}

	.btn-demo:hover {
		background: #f0f0f0;
	}

	@media (max-width: 768px) {
		.nav-container {
			flex-direction: column;
			padding: 1rem;
		}
		.nav-menu {
			margin: 1rem 0;
			gap: 1rem;
		}
	}
</style>