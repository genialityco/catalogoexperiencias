rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Carpeta events: lectura pública, escritura autenticada
    match /events/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Carpeta styles: lectura pública, escritura autenticada
    match /styles/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Carpeta tasks: lectura pública, escritura pública (photo booth)
    match /tasks/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }

    // Carpeta experiences: lectura pública, escritura pública limitada a imágenes <= 5MB
    // (para admin frontend sin auth)
    match /experiences/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.resource != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Otras carpetas: protegidas
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
